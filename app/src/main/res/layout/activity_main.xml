<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🎹 PianoLearn"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_light"/>

        <Button
            android:id="@+id/btn_lessons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lessons"
            android:backgroundTint="@color/primary"
            android:textColor="@color/text_light"/>
    </LinearLayout>

    <!-- Spacer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Piano Keyboard Container -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_marginBottom="32dp"
        android:layout_marginHorizontal="4dp">

        <!-- White Keys Row -->
        <LinearLayout
            android:id="@+id/white_keys"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <Button android:id="@+id/key_c"
                style="@style/WhiteKey" android:text="C"/>
            <Button android:id="@+id/key_d"
                style="@style/WhiteKey" android:text="D"/>
            <Button android:id="@+id/key_e"
                style="@style/WhiteKey" android:text="E"/>
            <Button android:id="@+id/key_f"
                style="@style/WhiteKey" android:text="F"/>
            <Button android:id="@+id/key_g"
                style="@style/WhiteKey" android:text="G"/>
            <Button android:id="@+id/key_a"
                style="@style/WhiteKey" android:text="A"/>
            <Button android:id="@+id/key_b"
                style="@style/WhiteKey" android:text="B"/>
            <Button android:id="@+id/key_c5"
                style="@style/WhiteKey" android:text="C"/>
        </LinearLayout>

        <!-- Black Keys Row (overlaid) -->
        <!-- Black keys are positioned manually using margins -->
        <!-- Each white key is 1/8 = 12.5% of total width -->
        <!-- Black key sits between two white keys -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingTop="0dp">

            <!-- Spacer before C# (center it between C and D: 75% of white key width) -->
            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="0.75"/>
            <Button android:id="@+id/key_cs" style="@style/BlackKey" android:text="C#"/>
            <!-- Spacer between C# and D# -->
            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="0.5"/>
            <Button android:id="@+id/key_ds" style="@style/BlackKey" android:text="D#"/>
            <!-- Spacer (E has no black key: 1 full white + some) -->
            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1.75"/>
            <Button android:id="@+id/key_fs" style="@style/BlackKey" android:text="F#"/>
            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="0.5"/>
            <Button android:id="@+id/key_gs" style="@style/BlackKey" android:text="G#"/>
            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="0.5"/>
            <Button android:id="@+id/key_as" style="@style/BlackKey" android:text="A#"/>
            <!-- Trailing spacer -->
            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="0.75"/>
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
